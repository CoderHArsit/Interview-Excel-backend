# Environment: development | staging | production
# This determines which config/*.yaml file is loaded as defaults.
# Env vars below OVERRIDE the YAML values.
APP_ENV=development
PORT=8080

# Neon (staging/prod) example:
#   DATABASE_URL=postgres://user:pass@ep-xxx.region.aws.neon.tech/interview_excel_staging?sslmode=require
# Local Postgres example:
DATABASE_URL=postgres://user:password@localhost:5432/interview_excel?sslmode=disable
DB_HOST=
DB_PORT=
DB_USER=
DB_NAME=
DB_PASSWORD=
DB_SSLMODE=disable
REDIS_ENABLED=false
REDIS_ADDR=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_USE_TLS=false
COOKIE_DOMAIN=
COOKIE_SECURE=false
CORS_ALLOWED_ORIGINS=http://localhost:3010
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/google_callback
GOOGLE_CREDENTIALS_JSON=
JWT_SECRET=
RAZORPAY_KEY=
RAZORPAY_SECRET=
